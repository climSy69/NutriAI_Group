<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvAppTitle"
            style="@style/TextAppearance.NutriAI.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NutriAI"
            android:layout_marginTop="@dimen/spacing_large"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            style="@style/TextAppearance.NutriAI.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:layout_marginBottom="@dimen/spacing_xlarge" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.NutriAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_normal">

            <Button
                android:id="@+id/btnAddMeal"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="Add Meal"
                android:textSize="@dimen/text_subtitle"
                app:icon="@android:drawable/ic_menu_add" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.NutriAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_normal">

            <Button
                android:id="@+id/btnWeekDiet"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="Week Diet"
                android:textSize="@dimen/text_subtitle"
                app:icon="@android:drawable/ic_menu_today" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.NutriAI.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large">

            <Button
                android:id="@+id/btnViewSummary"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="Daily Summary"
                android:textSize="@dimen/text_subtitle"
                app:icon="@android:drawable/ic_menu_info_details" />
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnProfile"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Profile"
            android:layout_marginBottom="@dimen/spacing_normal" />

        <Button
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@color/error_red"
            app:rippleColor="#20FF0000" />

    </LinearLayout>
</ScrollView>
