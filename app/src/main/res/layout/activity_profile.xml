<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <Button
            android:id="@+id/btnHome"
            style="@style/Widget.NutriAI.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:layout_gravity="start"
            android:minHeight="48dp"
            android:textSize="14sp"
            app:icon="@drawable/ic_home"
            android:layout_marginBottom="32dp" />

        <TextView
            style="@style/TextAppearance.NutriAI.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card_bg"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="4dp"
            android:layout_marginBottom="48dp">

            <TextView
                style="@style/TextAppearance.NutriAI.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvProfileEmail"
                style="@style/TextAppearance.NutriAI.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="24dp" />

            <TextView
                style="@style/TextAppearance.NutriAI.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvProfileId"
                style="@style/TextAppearance.NutriAI.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username: User"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnProfileLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Logout"
            android:textSize="18sp"
            android:textColor="@color/error_red" />

    </LinearLayout>
</ScrollView>
