<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_medium"
    android:background="@color/background_light"
    android:gravity="center_horizontal">

    <Button
        android:id="@+id/btnHome"
        style="@style/Widget.NutriAI.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:layout_gravity="start"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <TextView
        style="@style/TextAppearance.NutriAI.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:layout_marginTop="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/spacing_xlarge" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.NutriAI.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_large">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <TextView
                style="@style/TextAppearance.NutriAI.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvProfileEmail"
                style="@style/TextAppearance.NutriAI.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:layout_marginBottom="@dimen/spacing_medium" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_gray"
                android:layout_marginBottom="@dimen/spacing_medium" />

            <TextView
                android:id="@+id/tvProfileId"
                style="@style/TextAppearance.NutriAI.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username: User" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnProfileLogout"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textColor="@color/error_red"
        app:rippleColor="#20FF0000" />

</LinearLayout>
