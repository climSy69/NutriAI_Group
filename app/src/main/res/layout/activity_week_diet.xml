<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_medium"
    android:background="@color/background_light">

    <TextView
        android:id="@+id/tvWeekDietTitle"
        style="@style/TextAppearance.NutriAI.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Weekly Diet"
        android:layout_marginBottom="@dimen/spacing_small" />

    <TextView
        style="@style/TextAppearance.NutriAI.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Planned Meals for the Week"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/spacing_large"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmptyState"
        style="@style/TextAppearance.NutriAI.Subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your diet list is empty.\nStart by adding your first meal from the dashboard."
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_xlarge"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:id="@+id/containerMeals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_large" />

    </ScrollView>

</LinearLayout>
