<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ADVANCEDCOMPUTERSCIENCECN6008_1"
        android:usesCleartextTraffic="true">

        <!-- SplashActivity is now the first screen (Launcher) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Base.Theme.ADVANCEDCOMPUTERSCIENCECN6008_1">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".AddMealActivity"
            android:label="Add Meal"
            android:exported="false" />

        <activity
            android:name=".WeekDietActivity"
            android:label="Week Diet"
            android:exported="false" />

        <activity
            android:name=".AIAssistantActivity"
            android:label="AI Wellness Assistant"
            android:exported="false" />

        <activity
            android:name=".DailySummaryActivity"
            android:label="Daily Summary"
            android:exported="false" />

        <activity
            android:name=".ProfileActivity"
            android:label="Profile"
            android:exported="false" />

    </application>

</manifest>